# dbportal Environment Variables Example

# The primary database connection string (Required)
# Supported: postgres://, mongodb://, mysql://, sqlite:, mssql://, redis://
DATABASE_URL=postgres://user:password@localhost:5432/my_db

# Optional additional connections (DATABASE_URL_1 to DATABASE_URL_10)
# DATABASE_URL_1=mongodb://localhost:27017/logs
# DATABASE_URL_2=sqlite:./local.db

# The port the Express server will run on (Default: 3000)
PORT=3000

# Optional: Environment setting (development/production)
NODE_ENV=development
