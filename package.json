{
  "name": "dbportal",
  "version": "1.0.3",
  "description": "A local read-only database explorer for multiple connection strings.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dbportal": "bin/cli.js"
  },
  "files": [
    "dist",
    "bin",
    "frontend/dist"
  ],
  "scripts": {
    "dev": "tsup src/index.ts src/cli.ts --watch --format cjs,esm",
    "dev:ui": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend && tsup src/index.ts src/cli.ts --format cjs,esm --clean && tsc --emitDeclarationOnly --declaration --outDir dist",
    "build:all": "npm run build",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"frontend/src/**/*.{ts,tsx,css}\"",
    "check-format": "prettier --check \"src/**/*.ts\" \"frontend/src/**/*.{ts,tsx,css}\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "tsc --noEmit"
    ],
    "frontend/src/**/*.{ts,tsx,css}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "database",
    "gui",
    "viewer",
    "mongodb",
    "postgres",
    "mysql",
    "local"
  ],
  "author": "Manan Gupta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mananwebdev160408/dbportal.git"
  },
  "bugs": {
    "url": "https://github.com/Mananwebdev160408/dbportal/issues"
  },
  "homepage": "https://github.com/Mananwebdev160408/dbportal#readme",
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "mongodb": "^6.20.0",
    "mssql": "^12.2.1",
    "mysql2": "^3.15.2",
    "open": "^10.2.0",
    "pg": "^8.16.3",
    "redis": "^5.11.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/mssql": "^9.1.11",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.15.6",
    "@types/sqlite3": "^3.1.11",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "5.4"
  }
}
